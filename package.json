{
  "name": "@deerdaily/agent-github-codex",
  "version": "0.2.0",
  "description": "Deterministic Bun CLI harness for Git, GitHub CLI, and Codex CLI.",
  "module": "src/index.ts",
  "bin": {
    "agc": "./src/index.ts"
  },
  "type": "module",
  "preferGlobal": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": ["bun", "cli", "codex", "git", "github"],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "zod": "^4.3.6"
  }
}
